# Runtime
NODE_ENV=development
PORT=8000
HOST=0.0.0.0
LOG_LEVEL=info

# Database
DATABASE_URL=postgresql://lumina:lumina@localhost:15432/lumina?schema=public

# Observability
REQUEST_ID_HEADER=X-Request-ID
METRICS_ENABLED=true
METRICS_PATH=/metrics

# OpenTelemetry tracing (optional). Set endpoint to enable OTLP trace export.
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318/v1/traces
# OTEL_SERVICE_NAME=lumina-server

# Optional future infra (falls back to Noop/Prisma when missing)
REDIS_URL=redis://localhost:16379
CLICKHOUSE_URL=http://localhost:8123
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=lumina
CLICKHOUSE_DB=lumina

# Storage: local | s3
STORAGE_TYPE=local
LOCAL_STORAGE_BASE_URL=http://localhost:8000/api/v1
LOCAL_STORAGE_PATH=./uploads

# S3 / MinIO settings (used when STORAGE_TYPE=s3)
S3_ENDPOINT=http://localhost:9000
S3_BUCKET=lumina-artifacts
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_FORCE_PATH_STYLE=true

# Auth / workspace
# Default workspace id new users are seeded into.
LUMINA_DEFAULT_WORKSPACE_ID=default
# Dashboard URL printed in the startup banner (defaults to :3000 on the API host).
# LUMINA_DASHBOARD_URL=http://localhost:3000
# Self-service API-key recovery ("Forgot key?"). Comma-separated allowlist of
# emails permitted to rotate their own key WITHOUT auth. Empty (default)
# disables the endpoint entirely. Requests are rate-limited (5 / 15 min per
# email + IP) and allowlist misses are indistinguishable from unknown users.
# LUMINA_ROTATE_KEY_EMAILS=admin@example.com,ops@example.com

