# Runtime
NODE_ENV=development
PORT=8000
HOST=0.0.0.0
LOG_LEVEL=info

# Database
DATABASE_URL=postgresql://lumina:lumina@localhost:15432/lumina?schema=public

# Observability
REQUEST_ID_HEADER=X-Request-ID
METRICS_ENABLED=true
METRICS_PATH=/metrics

# Optional future infra (falls back to Noop/Prisma when missing)
REDIS_URL=redis://localhost:16379
CLICKHOUSE_URL=http://localhost:8123
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=lumina
CLICKHOUSE_DB=lumina

# Storage: local | s3
STORAGE_TYPE=local
LOCAL_STORAGE_BASE_URL=http://localhost:8000/api/v1
LOCAL_STORAGE_PATH=./uploads

# S3 / MinIO settings (used when STORAGE_TYPE=s3)
S3_ENDPOINT=http://localhost:9000
S3_BUCKET=lumina-artifacts
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_FORCE_PATH_STYLE=true
