generator client {
  provider      = "prisma-client-js"
  output        = "../src/generated/prisma"
  binaryTargets = ["native", "linux-arm64-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// Identity & Access
// ============================================================

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  apiKey    String?  @unique
  name      String?
  avatar    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  memberships WorkspaceMembership[]

  @@index([email])
  @@index([apiKey])
}

model Workspace {
  id          String   @id @default(uuid())
  name        String   @unique
  displayName String?
  settings    Json     @default("{}")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  memberships WorkspaceMembership[]
  projects    Project[]

  @@index([name])
}

model WorkspaceMembership {
  id          String              @id @default(uuid())
  workspaceId String
  userId      String
  role        WorkspaceRole       @default(member)
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, userId])
  @@index([userId])
}

enum WorkspaceRole {
  owner
  admin
  member
  viewer
}

// ============================================================
// Project
// ============================================================

model Project {
  id          String   @id @default(uuid())
  workspaceId String
  name        String
  displayName String?
  description String?
  settings    Json     @default("{}")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace    Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  runs         Run[]
  sweeps       Sweep[]
  metrics      Metric[]
  logLines     LogLine[]
  systemMetrics SystemMetric[]
  tags         Tag[]
  artifacts    Artifact[]
  reports      Report[]
  runMedia     RunMedia[]
  registryModels RegistryModel[]
  evaluations  Evaluation[]
  traces       Trace[]
  launchQueues LaunchQueue[]
  launchJobs   LaunchJob[]
  launchRuns   LaunchRun[]

  @@unique([workspaceId, name])
  @@index([workspaceId, createdAt])
}

// ============================================================
// Run
// ============================================================

model Run {
  id          String   @id @default(uuid())
  runId       String   @unique // UUID v7, globally unique across regions/projects
  projectId   String
  sweepId     String?
  name        String
  status      RunStatus @default(running)
  config      Json     @default("{}")
  summary     Json     @default("{}")
  notes       String?
  metadata    Json     @default("{}")
  /// SDK telemetry envelope (CLI/library versions, GPU/CPU flags).
  /// Mirrors wandb's TelemetryRecord proto; full schema lives in metadata.
  telemetry   Json     @default("{}")
  /// Metric definitions (name -> {step, hidden, summaryType, ...}). Folded
  /// into the existing PATCH /runs/:id route via UpdateRunSchema.
  metricDefs  Json     @default("{}")
  /// Optional human-readable alias shown in the dashboard; independent of
  /// the immutable `runId` (UUID v7). Step 3.2 sends this from the SDK
  /// sender to keep wandb's displayName parity.
  displayName String?
  /// Optional grouping hint (used by sweeps / launch to fan out jobs).
  group       String?
  /// Optional job type ("train" / "eval" / "sweep-agent" / ...).
  jobType     String?
  startedAt   DateTime @default(now())
  finishedAt  DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  project       Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  sweep         Sweep?         @relation(fields: [sweepId], references: [id], onDelete: SetNull)
  metrics       Metric[]
  logLines      LogLine[]
  systemMetrics SystemMetric[]
  tags          RunTag[]
  evaluations   Evaluation[]
  traces        Trace[]
  runMedia      RunMedia[]
  launchRuns    LaunchRun[]
  alerts        RunAlert[]
  useArtifacts  RunUseArtifact[]

  @@index([projectId, createdAt])
  @@index([projectId, status])
  @@index([projectId, name])
  @@index([runId])
  @@index([sweepId, createdAt])
}

enum RunStatus {
  pending
  running
  finished
  failed
  crashed
  killed
  preempting
}

// ============================================================
// Sweeps
// ============================================================

model Sweep {
  id          String   @id @default(uuid())
  projectId   String
  name        String
  method      String   // random | grid | bayes
  config      Json     @default("{}")
  state       SweepState @default(running)
  bestRunId   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  runs    Run[]

  @@unique([projectId, name])
  @@index([projectId, createdAt])
  @@index([projectId, state])
}

enum SweepState {
  pending
  running
  finished
  crashed
  cancelled
}

// ============================================================
// Tags
// ============================================================

model Tag {
  id        String   @id @default(uuid())
  projectId String
  name      String
  color     String?
  createdAt DateTime @default(now())

  project Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  runs    RunTag[]

  @@unique([projectId, name])
}

model RunTag {
  id     String @id @default(uuid())
  runId  String
  tagId  String

  run Run @relation(fields: [runId], references: [runId], onDelete: Cascade)
  tag Tag @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([runId, tagId])
  @@index([tagId])
}

// ============================================================
// Metrics
// ============================================================

model Metric {
  id        String   @id @default(uuid())
  runId     String
  projectId String
  key       String
  step      Int      @default(0)
  value     Float
  metadata  Json     @default("{}")
  loggedAt  DateTime @default(now())

  run     Run     @relation(fields: [runId], references: [runId], onDelete: Cascade)
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([runId, key, step])
  @@index([projectId, key, loggedAt])
  @@index([runId, loggedAt])
}

model SystemMetric {
  id        String   @id @default(uuid())
  runId     String
  projectId String
  key       String
  step      Int      @default(0)
  value     Float
  loggedAt  DateTime @default(now())

  run     Run     @relation(fields: [runId], references: [runId], onDelete: Cascade)
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([runId, key, loggedAt])
  @@index([projectId, key, loggedAt])
}

// ============================================================
// Logs
// ============================================================

model LogLine {
  id        String   @id @default(uuid())
  runId     String
  projectId String
  level     String   @default("INFO")
  message   String
  step      Int?
  timestamp DateTime @default(now())

  run     Run     @relation(fields: [runId], references: [runId], onDelete: Cascade)
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([runId, timestamp])
  @@index([projectId, timestamp])
}

// ============================================================
// Artifacts
// ============================================================

model Artifact {
  id          String           @id @default(uuid())
  projectId   String
  name        String
  type        ArtifactType     @default(file)
  description String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  project   Project            @relation(fields: [projectId], references: [id], onDelete: Cascade)
  versions  ArtifactVersion[]

  @@unique([projectId, name])
  @@index([projectId, createdAt])
}

enum ArtifactType {
  dataset
  model
  checkpoint
  file
  table
}

model ArtifactVersion {
  id          String            @id @default(uuid())
  artifactId  String
  version     String
  aliases     String[]          @default([])
  metadata    Json              @default("{}")
  state       ArtifactVersionState @default(committed)
  /// sha256 digest over the canonical manifest, populated on finalize.
  digest      String?
  /// Serialized manifest entries (path, digest, size, referenceUri, contentType).
  manifest    Json?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  artifact Artifact            @relation(fields: [artifactId], references: [id], onDelete: Cascade)
  files    ArtifactFile[]
  parents  ArtifactLineage[]   @relation("ChildVersion")
  children ArtifactLineage[]   @relation("ParentVersion")
  evaluationsAsDataset Evaluation[] @relation("EvaluationDataset")
  evaluationsAsModel   Evaluation[] @relation("EvaluationModel")
  registryModelVersions RegistryModelVersion[]
  runMedia RunMedia[]
  portfolioLinks ArtifactPortfolioLink[]
  useByRuns RunUseArtifact[]

  @@unique([artifactId, version])
  @@index([artifactId, createdAt])
}

enum ArtifactVersionState {
  pending
  committed
  deleted
}

model ArtifactFile {
  id                  String   @id @default(uuid())
  artifactVersionId   String
  path                String
  size                BigInt   @default(0)
  md5                 String?
  /// Content-addressed sha256 (lowercase hex). Null for reference artifacts.
  sha256              String?
  /// Optional ETag / opaque server-side tag.
  etag                String?
  /// External URI for reference artifacts (e.g. s3://, https://). When set,
  /// `storageKey` is null and no upload is required.
  referenceUri        String?
  /// MIME type hint supplied by the uploader.
  contentType         String?
  storageKey          String?
  createdAt           DateTime @default(now())

  artifactVersion ArtifactVersion @relation(fields: [artifactVersionId], references: [id], onDelete: Cascade)

  @@unique([artifactVersionId, path])
  @@index([artifactVersionId, sha256])
}

model ArtifactLineage {
  id                      String   @id @default(uuid())
  artifactVersionId       String
  parentArtifactVersionId String
  type                    String   @default("derived_from")

  artifactVersion       ArtifactVersion @relation("ChildVersion", fields: [artifactVersionId], references: [id], onDelete: Cascade)
  parentArtifactVersion ArtifactVersion @relation("ParentVersion", fields: [parentArtifactVersionId], references: [id], onDelete: Cascade)

  @@unique([artifactVersionId, parentArtifactVersionId])
  @@index([parentArtifactVersionId])
}

/// Mirrors wandb's LinkArtifact mutation. A version is "linked" to a
/// portfolio (registry) with a list of aliases (e.g. "latest", "v1.2").
model ArtifactPortfolioLink {
  id                String   @id @default(uuid())
  artifactVersionId String
  portfolioName     String
  portfolioEntity   String?
  portfolioProject  String
  aliases           String[] @default([])
  versionIndex      Int      @default(0)
  createdAt         DateTime @default(now())

  artifactVersion ArtifactVersion @relation(fields: [artifactVersionId], references: [id], onDelete: Cascade)

  @@unique([artifactVersionId, portfolioProject, portfolioName])
  @@index([portfolioProject, portfolioName])
}

// ============================================================
// Run-scoped append-only events (alerts, use_artifact)
// ============================================================

/// Mirrors wandb's notify_scriptable_run_alert mutation. Append-only.
model RunAlert {
  id        String   @id @default(uuid())
  runId     String
  title     String
  text      String
  /// One of "INFO" | "WARN" | "ERROR".
  level     String   @default("INFO")
  createdAt DateTime @default(now())

  run Run @relation(fields: [runId], references: [runId], onDelete: Cascade)

  @@index([runId, createdAt])
}

/// Mirrors wandb's UseArtifact mutation. Records that a run referenced
/// a specific artifact version.
model RunUseArtifact {
  id                String   @id @default(uuid())
  runId             String
  artifactVersionId String
  /// Free-form tag from the SDK ("input", "output", "job", etc.).
  useType           String?
  createdAt         DateTime @default(now())

  run             Run             @relation(fields: [runId], references: [runId], onDelete: Cascade)
  artifactVersion ArtifactVersion @relation(fields: [artifactVersionId], references: [id], onDelete: Cascade)

  @@unique([runId, artifactVersionId, useType])
  @@index([artifactVersionId])
}

// ============================================================
// Reports
// ============================================================

model Report {
  id        String   @id @default(uuid())
  projectId String
  title     String
  blocks    Json     @default("[]")
  createdBy String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, createdAt])
}

// ============================================================
// Tables & Media
// ============================================================

model RunMedia {
  id                String    @id @default(uuid())
  runId             String
  projectId         String
  key               String
  type              MediaType
  artifactVersionId String
  metadata          Json      @default("{}")
  createdAt         DateTime  @default(now())

  run             Run             @relation(fields: [runId], references: [runId], onDelete: Cascade)
  project         Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  artifactVersion ArtifactVersion @relation(fields: [artifactVersionId], references: [id], onDelete: Cascade)

  @@index([runId, createdAt])
  @@index([projectId, createdAt])
}

enum MediaType {
  table
  image
  video
  audio
  plotly
  html
  file
}

// ============================================================
// Model Registry
// ============================================================

model RegistryModel {
  id          String   @id @default(uuid())
  projectId   String
  name        String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  project  Project               @relation(fields: [projectId], references: [id], onDelete: Cascade)
  versions RegistryModelVersion[]

  @@unique([projectId, name])
}

model RegistryModelVersion {
  id                  String   @id @default(uuid())
  registryModelId     String
  version             String
  artifactVersionId   String
  aliases             String[] @default([])
  metadata            Json     @default("{}")
  createdAt           DateTime @default(now())

  registryModel   RegistryModel   @relation(fields: [registryModelId], references: [id], onDelete: Cascade)
  artifactVersion ArtifactVersion @relation(fields: [artifactVersionId], references: [id], onDelete: Cascade)

  @@unique([registryModelId, version])
  @@index([registryModelId, createdAt])
}

// ============================================================
// Evaluations
// ============================================================

model Evaluation {
  id                       String   @id @default(uuid())
  projectId                String
  name                     String
  runId                    String?
  datasetArtifactVersionId String?
  modelArtifactVersionId   String?
  status                   EvaluationStatus @default(pending)
  summary                  Json     @default("{}")
  metadata                 Json     @default("{}")
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt

  project              Project            @relation(fields: [projectId], references: [id], onDelete: Cascade)
  run                  Run?               @relation(fields: [runId], references: [runId], onDelete: SetNull)
  datasetArtifactVersion ArtifactVersion? @relation("EvaluationDataset", fields: [datasetArtifactVersionId], references: [id], onDelete: SetNull)
  modelArtifactVersion   ArtifactVersion? @relation("EvaluationModel", fields: [modelArtifactVersionId], references: [id], onDelete: SetNull)
  results                EvaluationResult[]

  @@index([projectId, createdAt])
  @@index([projectId, status])
}

enum EvaluationStatus {
  pending
  running
  completed
  failed
}

model EvaluationResult {
  id            String   @id @default(uuid())
  evaluationId  String
  key           String
  value         Float
  metadata      Json     @default("{}")
  createdAt     DateTime @default(now())

  evaluation Evaluation @relation(fields: [evaluationId], references: [id], onDelete: Cascade)

  @@index([evaluationId, key])
}

// ============================================================
// Launch (Job Scheduling)
// ============================================================

model LaunchQueue {
  id          String   @id @default(uuid())
  projectId   String
  name        String
  config      Json     @default("{}")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  project Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  runs    LaunchRun[]

  @@unique([projectId, name])
  @@index([projectId, createdAt])
}

model LaunchJob {
  id          String   @id @default(uuid())
  projectId   String
  name        String
  image       String?
  command     String[] @default([])
  args        String[] @default([])
  env         Json     @default("{}")
  config      Json     @default("{}")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  project Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  runs    LaunchRun[]

  @@unique([projectId, name])
  @@index([projectId, createdAt])
}

model LaunchRun {
  id            String   @id @default(uuid())
  projectId     String
  queueId       String
  jobId         String
  runId         String?
  status        LaunchRunStatus @default(pending)
  metadata      Json     @default("{}")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  project Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  queue   LaunchQueue   @relation(fields: [queueId], references: [id], onDelete: Cascade)
  job     LaunchJob     @relation(fields: [jobId], references: [id], onDelete: Cascade)
  run     Run?          @relation(fields: [runId], references: [runId], onDelete: SetNull)

  @@index([queueId, status, createdAt])
  @@index([projectId, createdAt])
}

enum LaunchRunStatus {
  pending
  running
  completed
  failed
  cancelled
}

// ============================================================
// Traces (LLM / Agent Observability)
// ============================================================

model Trace {
  id        String   @id @default(uuid())
  projectId String
  runId     String?
  traceId   String   @unique
  name      String
  status    TraceStatus @default(ok)
  latencyMs Int?
  metadata  Json     @default("{}")
  startedAt DateTime @default(now())
  finishedAt DateTime?
  createdAt DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  run     Run?    @relation(fields: [runId], references: [runId], onDelete: SetNull)
  spans   Span[]

  @@index([projectId, startedAt])
  @@index([traceId])
}

enum TraceStatus {
  ok
  error
}

model Span {
  id           String   @id @default(uuid())
  traceId      String
  parentSpanId String?
  spanId       String   @unique
  name         String
  kind         SpanKind @default(internal)
  input        Json     @default("{}")
  output       Json     @default("{}")
  latencyMs    Int?
  status       SpanStatus @default(ok)
  startedAt    DateTime @default(now())
  finishedAt   DateTime?
  createdAt    DateTime @default(now())

  trace      Trace  @relation(fields: [traceId], references: [id], onDelete: Cascade)
  parentSpan Span?  @relation("SpanChildren", fields: [parentSpanId], references: [id], onDelete: Cascade)
  childSpans Span[] @relation("SpanChildren")

  @@index([traceId, startedAt])
  @@index([parentSpanId])
}

enum SpanKind {
  llm
  tool
  retriever
  chain
  agent
  internal
}

enum SpanStatus {
  ok
  error
}
