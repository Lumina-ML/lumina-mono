{
  "name": "@lumina/server",
  "version": "0.1.0",
  "private": true,
  "description": "Lumina backend server",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "worker": "tsx watch src/worker.ts",
    "start": "node dist/index.js",
    "worker:prod": "node dist/worker.js",
    "test": "vitest run",
    "test:e2e": "vitest run --config vitest.e2e.config.ts",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist node_modules",
    "db:migrate": "prisma migrate dev",
    "db:generate": "prisma generate",
    "db:studio": "prisma studio"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1090.0",
    "@aws-sdk/s3-request-presigner": "^3.1090.0",
    "@clickhouse/client": "^1.23.1",
    "@fastify/cors": "^9.0.0",
    "@fastify/multipart": "^10.1.0",
    "@fastify/websocket": "^8.3.1",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/exporter-trace-otlp-http": "^0.53.0",
    "@opentelemetry/resources": "^1.25.0",
    "@opentelemetry/sdk-node": "^0.53.0",
    "@opentelemetry/semantic-conventions": "^1.25.0",
    "@prisma/client": "^5.16.0",
    "bullmq": "^5.80.8",
    "fastify": "^4.28.0",
    "fastify-plugin": "^4.5.0",
    "ioredis": "^5.11.1",
    "pino": "^9.2.0",
    "prisma": "^5.16.0",
    "prom-client": "^15.1.3",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@testcontainers/clickhouse": "11",
    "@testcontainers/minio": "11",
    "@testcontainers/postgresql": "^11.14.0",
    "@testcontainers/redis": "^11.14.0",
    "@types/node": "^20.14.0",
    "@types/pg": "^8.20.0",
    "@types/ws": "^8.18.1",
    "eslint": "^8.57.0",
    "pg": "^8.22.0",
    "pino-pretty": "^13.0.0",
    "testcontainers": "^11.14.0",
    "tsx": "^4.15.0",
    "typescript": "^5.5.0",
    "vitest": "^1.6.0"
  }
}
