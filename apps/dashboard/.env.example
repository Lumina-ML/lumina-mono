# Dashboard dev server port (optional, defaults to Vite's default)
# PORT=3000

# Lumina server API URL (used at build time).
# Leave empty to use the same origin (useful when the dashboard is served
# behind the same reverse proxy as the API).
VITE_LUMINA_API_URL=http://localhost:8000

# Optional: pre-fill the default API key for local development.
# In production the user must log in through the dashboard UI.
# VITE_LUMINA_API_KEY=
